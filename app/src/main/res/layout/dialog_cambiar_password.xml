<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- ACTUAL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="CONTRASEÑA ACTUAL *"
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDlgActual"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:boxStrokeColor="#0B2458"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintEnabled="false"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#0B2458"
            app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
            app:startIconTint="#667085">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDlgActual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tu contraseña actual"
                android:inputType="textPassword"
                android:minHeight="56dp"
                android:paddingVertical="14dp"
                android:textColor="#0B2458"
                android:textColorHint="#9E9E9E"
                android:textCursorDrawable="@null"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- NUEVA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="NUEVA CONTRASEÑA *"
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDlgNueva"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:boxStrokeColor="#0B2458"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintEnabled="false"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#0B2458"
            app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
            app:startIconTint="#667085">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDlgNueva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mínimo 6 caracteres"
                android:inputType="textPassword"
                android:minHeight="56dp"
                android:paddingVertical="14dp"
                android:textColor="#0B2458"
                android:textColorHint="#9E9E9E"
                android:textCursorDrawable="@null"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Indicador de fortaleza -->
        <TextView
            android:id="@+id/tvFortaleza"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Fortaleza: —"
            android:textColor="#667085"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- CONFIRMAR -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="CONFIRMAR NUEVA CONTRASEÑA *"
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDlgConfirmar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:boxStrokeColor="#0B2458"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintEnabled="false"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#0B2458"
            app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
            app:startIconTint="#667085">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDlgConfirmar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Repite la nueva contraseña"
                android:inputType="textPassword"
                android:minHeight="56dp"
                android:paddingVertical="14dp"
                android:textColor="#0B2458"
                android:textColorHint="#9E9E9E"
                android:textCursorDrawable="@null"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
