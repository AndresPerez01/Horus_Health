<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- ===== VISTA PREVIA DE LA TARJETA ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/card_preview_bg"
            android:elevation="6dp"
            android:padding="20dp">

            <!-- Contactless arriba a la derecha -->
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="44dp"
                android:contentDescription="Contactless"
                android:src="@drawable/ic_card_contactless" />

            <!-- Chip -->
            <ImageView
                android:layout_width="34dp"
                android:layout_height="26dp"
                android:layout_gravity="top|start"
                android:contentDescription="Chip"
                android:src="@drawable/ic_card_chip" />

            <!-- Distintivo de marca -->
            <TextView
                android:id="@+id/tvCardBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="@drawable/card_brand_badge_bg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="TARJETA"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold|italic"
                android:letterSpacing="0.12" />

            <!-- Número -->
            <TextView
                android:id="@+id/tvCardNumero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="18dp"
                android:fontFamily="monospace"
                android:text="•••• •••• •••• ••••"
                android:textColor="#FFFFFF"
                android:textSize="21sp"
                android:letterSpacing="0.08"
                android:textStyle="bold" />

            <!-- Titular y expiración abajo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TITULAR"
                        android:textColor="#B9C6E6"
                        android:textSize="9sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvCardTitular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="NOMBRE APELLIDO"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EXPIRA"
                        android:textColor="#B9C6E6"
                        android:textSize="9sp"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvCardExp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MM/AA"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- ===== CAMPOS ===== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="TITULAR DE LA TARJETA *"
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDlgTitular"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:boxStrokeColor="#0B2458"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintEnabled="false"
            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
            app:startIconTint="#667085">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDlgTitular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Como aparece en la tarjeta"
                android:inputType="textPersonName|textCapWords"
                android:minHeight="56dp"
                android:paddingVertical="14dp"
                android:textColor="#0B2458"
                android:textColorHint="#9E9E9E"
                android:textCursorDrawable="@null"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="NÚMERO DE TARJETA *"
            android:textColor="#424242"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDlgNumero"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp"
            app:boxStrokeColor="#0B2458"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintEnabled="false"
            app:startIconDrawable="@android:drawable/ic_menu_gallery"
            app:startIconTint="#667085">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDlgNumero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0000 0000 0000 0000"
                android:inputType="number"
                android:maxLength="19"
                android:minHeight="56dp"
                android:paddingVertical="14dp"
                android:textColor="#0B2458"
                android:textColorHint="#9E9E9E"
                android:textCursorDrawable="@null"
                android:textSize="18sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="EXPIRACIÓN *"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutDlgExp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxStrokeColor="#0B2458"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDlgExp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="MM/AA"
                        android:inputType="number"
                        android:maxLength="5"
                        android:minHeight="56dp"
                        android:paddingVertical="14dp"
                        android:textColor="#0B2458"
                        android:textColorHint="#9E9E9E"
                        android:textCursorDrawable="@null"
                        android:textSize="18sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="CVV *"
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutDlgCvv"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxStrokeColor="#0B2458"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintEnabled="false"
                    app:endIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:endIconMode="custom"
                    app:endIconTint="#667085">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDlgCvv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="123"
                        android:inputType="numberPassword"
                        android:maxLength="4"
                        android:minHeight="56dp"
                        android:paddingVertical="14dp"
                        android:textColor="#0B2458"
                        android:textColorHint="#9E9E9E"
                        android:textCursorDrawable="@null"
                        android:textSize="18sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawablePadding="6dp"
            android:gravity="center_vertical"
            android:text="Por tu seguridad no guardamos el número completo ni el CVV."
            android:textColor="#667085"
            android:textSize="12sp"
            app:drawableStartCompat="@android:drawable/ic_lock_idle_lock"
            app:drawableTint="#667085" />

    </LinearLayout>
</ScrollView>
