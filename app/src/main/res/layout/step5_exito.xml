<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <LinearLayout
        android:id="@+id/headerExito"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0B2458"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/logo_horus_sin_titulo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Horus Health"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardBackgroundColor="#E6F4EA"
                app:cardCornerRadius="40dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="✓"
                    android:textColor="#0E5C2F"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/headerExito"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Cita Agendada!"
                android:textColor="#0B2458"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:text="Tu cita ha sido registrada\nexitosamente en el sistema."
                android:textAlignment="center"
                android:textColor="#667085"
                android:textSize="16sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="10dp"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Especialidad" android:textColor="#A0B3D6" />
                        <TextView android:id="@+id/tvExitoEspecialidad"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Especialidad" android:textColor="#0B2458" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Médico" android:textColor="#A0B3D6" />
                        <TextView android:id="@+id/tvExitoMedico" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nombre" android:textColor="#0B2458" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Lugar" android:textColor="#A0B3D6" />
                        <TextView android:id="@+id/tvExitoLugar" android:layout_width="160dp" android:layout_height="wrap_content" android:text="Clínica y consultorio" android:textColor="#0B2458" android:textStyle="bold" android:textAlignment="viewEnd" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F4F6F9" android:layout_marginTop="4dp" android:layout_marginBottom="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fecha" android:textColor="#A0B3D6" />
                        <TextView android:id="@+id/tvExitoFecha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fecha" android:textColor="#0B2458" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Hora" android:textColor="#A0B3D6" />
                        <TextView android:id="@+id/tvExitoHora" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hora" android:textColor="#0B2458" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#F4F8FF"
                app:cardCornerRadius="10dp"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔔 Recibirás recordatorio por email y SMS" android:textColor="#0B2458" android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVolverInicio"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Volver al inicio"
                android:textAllCaps="false"
                android:textColor="#424242"
                android:textSize="16sp"
                app:backgroundTint="#EAECEF"
                app:cornerRadius="10dp"
                app:elevation="0dp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>