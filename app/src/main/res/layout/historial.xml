<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <!-- ENCABEZADO -->
    <LinearLayout
        android:id="@+id/headerHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0B2458"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnVolverAtras"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#16397A"
            app:cardCornerRadius="10dp"
            app:strokeWidth="0dp">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#FFFFFF" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Mis Citas"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View android:layout_width="40dp" android:layout_height="40dp" />
    </LinearLayout>

    <!-- Usamos NestedScrollView para que los RecyclerViews hagan scroll correctamente -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/barraInferior"
        android:layout_below="@+id/headerHistorial"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="PRÓXIMAS"
                android:textColor="#667085"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProximas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:nestedScrollingEnabled="false"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="HISTORIAL"
                android:textColor="#667085"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPasadas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:nestedScrollingEnabled="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVolverInicio"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="← Volver al inicio"
                android:textAllCaps="false"
                android:textColor="#424242"
                android:textSize="16sp"
                app:backgroundTint="#EAECEF"
                app:cornerRadius="10dp"
                app:elevation="0dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BARRA DE NAVEGACIÓN INFERIOR (Sin cambios) -->
    <LinearLayout
        android:id="@+id/barraInferior"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingTop="8dp">
        <!-- Contenido de tu barra inferior se mantiene igual -->
    </LinearLayout>
</RelativeLayout>